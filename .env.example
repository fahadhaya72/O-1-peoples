# Environment Configuration
# Copy this file to .env and update values

# === DATABASE ===
DATABASE_URL="postgresql://user:password@localhost:5432/o1_peoples_db"

# === REDIS ===
REDIS_URL="redis://localhost:6379"

# === JWT ===
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRY="7d"

# === BACKEND ===
NODE_ENV="development"
PORT=3000
BACKEND_URL="http://localhost:3000"

# === FRONTEND ===
VITE_API_URL="http://localhost:3000"
VITE_WS_URL="ws://localhost:3000"

# === JUDGE ===
JUDGE_PORT=3001
JUDGE_WORKERS=3
DOCKER_SOCKET="/var/run/docker.sock"

# === FILE STORAGE ===
STORAGE_PATH="./storage"
MAX_FILE_SIZE=10485760 # 10MB

# === RATE LIMITS ===
RATE_LIMIT_SUBMIT_PER_MIN=12 # 1 every 5 sec = 12/min
RATE_LIMIT_RUN_PER_MIN=10
RATE_LIMIT_LOGIN_PER_MIN=5

# === LOGGING ===
LOG_LEVEL="info"

# === CORS ===
CORS_ORIGIN="http://localhost:5173"

# === CONTEST SETTINGS ===
CONTEST_MAX_PROBLEMS=6
SUBMISSION_TIMEOUT=3
CONTEST_MAX_PARTICIPANTS=400
